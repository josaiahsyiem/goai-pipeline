# ─── LLM providers ───────────────────────────────────────
# Groq — primary LLM (get keys at https://console.groq.com)
# Multiple keys rotate round-robin to multiply the free-tier limit.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=

# OpenAI — fallback LLM + embeddings (https://platform.openai.com)
OPENAI_API_KEY=

# ─── Datastores (defaults match docker-compose) ──────────
POSTGRES_HOST=goai_postgres
POSTGRES_PORT=5432
POSTGRES_DB=goai
POSTGRES_USER=goai
POSTGRES_PASSWORD=change_me
REDIS_URL=redis://goai_redis:6379/0
QDRANT_HOST=goai_qdrant

# ─── Dashboards ──────────────────────────────────────────
GRAFANA_PASSWORD=change_me

# ─── Optional: Langfuse observability ────────────────────
# Leave blank to disable. (https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ─── Behaviour flags ─────────────────────────────────────
SKIP_DETERMINISTIC=false
